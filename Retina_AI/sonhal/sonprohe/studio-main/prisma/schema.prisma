generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id            String     @id @default(cuid())
  fullName      String
  tcNo          String
  age           Int
  gender        String?
  diabetesYears Int?
  hba1c         Float?
  risk          String     @default("Yok")
  createdAt     DateTime   @default(now())

  analyses      Analysis[]
}

model Analysis {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  aiResult       String   // ODIR / DR etiketi
  confidence     Float
  heatmapUrl     String?  @db.Text
  originalImage  String?  @db.Text
  doctorNote     String?

  // Yeni alanlar JSON olarak ekleniyor
  aiOdriLabels     String?  @db.Text
  aiOdriConfidences String?  @db.Text

  createdAt      DateTime @default(now())
}
